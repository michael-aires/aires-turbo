# ===========================================================================
# Aires Headless CRM — root .env
# Copy to `.env` and fill in. Never commit real secrets.
# Group-by-group reference. If the group is commented out, the apps that
# consume it gracefully self-disable (see Quickstart §"Common gotchas").
# ===========================================================================

# ─── 1. Core infra (REQUIRED) ──────────────────────────────────────────────
# One Postgres instance shared across core, workers, mcp-server.
POSTGRES_URL=postgres://aires:aires@localhost:5432/aires
# Some apps/libs read DATABASE_URL instead (Drizzle, Railway defaults). Keep
# both in sync.
DATABASE_URL=${POSTGRES_URL}
# Upper bound for the shared pg pool. Default is reasonable; only raise
# if you see "too many connections" under load.
# DATABASE_POOL_MAX=20

# One Redis instance shared across all apps (BullMQ + chat ring buffer + rate
# limiting + session state).
REDIS_URL=redis://localhost:6379

# ─── 2. Auth (REQUIRED) ────────────────────────────────────────────────────
# 48 random bytes. Generate: `openssl rand -base64 48`.
# Must be identical across core + chat-web + agent-harness + chat-bots.
BETTER_AUTH_SECRET=change-me-to-48-random-bytes
# chat-web uses `AUTH_SECRET` as the Better-Auth secret via its env shim.
# Keep it in sync with BETTER_AUTH_SECRET.
AUTH_SECRET=${BETTER_AUTH_SECRET}

# Public URL that core is served from. Used as the JWKs issuer and for
# Better-Auth cookie domain. Browser-visible in dev.
CORE_PUBLIC_URL=http://localhost:4000

# Optional OAuth providers. Leave blank to hide the Google button on the
# login page.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ─── 3. Service URLs (REQUIRED for anything that talks to another app) ────
# Private URL workers/mcp-server/agent-harness/chat-bots use to call core.
# In dev == CORE_PUBLIC_URL. On Railway == http://core.railway.internal:8080.
CORE_INTERNAL_URL=http://localhost:4000

# Where the agent harness lives (chat-web + chat-bots call this).
HARNESS_INTERNAL_URL=http://localhost:4300

# Where the MCP server lives (agent-harness calls this to discover tools).
MCP_SERVER_URL=http://localhost:4200

# Where the WhatsApp / SMS bot app lives (core calls this for inbound
# webhooks routing).
CHAT_BOTS_INTERNAL_URL=http://localhost:4400

# chat-web self URL (used by Better-Auth for cookie issuance).
CHAT_WEB_BASE_URL=http://localhost:3100
CHAT_WEB_PRODUCTION_URL=${CHAT_WEB_BASE_URL}

# Space-separated or comma-separated list of origins that can call core's
# cookie-authenticated endpoints. On Railway, add chat-web's public URL.
# CORS_ALLOWED_ORIGINS=https://chat-web-production-xxxx.up.railway.app

# ─── 4. Single-tenant identifiers (REQUIRED after seed) ────────────────────
# Populated by `pnpm -F @acme/core tsx scripts/seed-dev-user.ts`.
# The script prints both values at the end — paste them here.
SINGLE_ORG_ID=
DEFAULT_AGENT_ID=

# ─── 5. Agent harness / LLM providers (AT LEAST ONE REQUIRED) ─────────────
# Which provider the harness uses by default. Must match a key set below.
AGENT_DEFAULT_MODEL=claude           # claude | gpt | gemini
# Optional: env var that lets a request override the default at runtime.
# Set to something like FF_AGENT_MODEL_OVERRIDE=true to enable.
# FF_AGENT_MODEL_OVERRIDE=

# Pick at least one. Others may stay blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Chat ring-buffer cap (messages per thread kept in Redis). Default 100.
# CHAT_THREAD_MAX_MESSAGES=100

# Agent JWT lifetime (short — agents refresh via their API key).
# AGENT_JWT_TTL_SECONDS=900

# ─── 6. Email (SendGrid) ───────────────────────────────────────────────────
# Workers' email queue self-disables if SENDGRID_API_KEY is blank.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@aires.tech

# ─── 7. Voice / SMS (Aircall + Twilio) ─────────────────────────────────────
# Aircall: outbound calls + SMS + activity sync (workers).
AIRCALL_API_ID=
AIRCALL_API_TOKEN=

# Twilio: inbound WhatsApp + SMS (chat-bots + core webhook verifier).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=               # e.g. whatsapp:+14155238886

# Credentials the chat-bots service uses to authenticate to core.
# Generate BOT_AGENT_ID by seeding an extra agent named "chat-bots-runtime"
# (see DEV_QUICKSTART §Path B). BOT_API_KEY is minted via
# POST /api/v1/agents/:id/api-keys.
BOT_AGENT_ID=
BOT_API_KEY=
# 16+ random bytes, used to sign internal core <-> chat-bots requests.
# `openssl rand -hex 24`.
BOT_INTERNAL_SECRET=

# ─── 8. Contracts / e-signature (DocuSeal) ────────────────────────────────
# Workers' contracts queue self-disables if blank.
DOCUSEAL_API_KEY=

# ─── 9. Blackline (report sync) ────────────────────────────────────────────
# Workers' reports queue self-disables if blank.
BLACKLINE_API_TOKEN=

# ─── 10. Observability ─────────────────────────────────────────────────────
LOG_LEVEL=info                      # trace | debug | info | warn | error
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://...

# ─── 11. One-time seed knobs (OPTIONAL) ────────────────────────────────────
# Only needed when you run the seed script.
# SEED_EMAIL=michael@aires.ai
# SEED_PASSWORD=ChangeMe!23
# SEED_NAME="Michael Moll"
# SEED_ORG_NAME=Aires

# ─── 12. PXP bootstrap (OPTIONAL) ──────────────────────────────────────────
# Only needed if you run `pnpm pxp:bootstrap` to seed from PXP Mongo.
# PXP_MONGO_URL=
