# ---------------------------------------------------------------------------
# Aires Headless CRM — root .env
# Copy to .env and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Database & cache -------------------------------------------------------
POSTGRES_URL=postgres://aires:aires@localhost:5432/aires
REDIS_URL=redis://localhost:6379

# --- Auth (Better-Auth) -----------------------------------------------------
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=change-me-to-48-random-bytes
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Service URLs -----------------------------------------------------------
# Public URL that JWKs are served from (browser-visible in dev).
CORE_PUBLIC_URL=http://localhost:4000
# Private URL workers/mcp-server use to call core (unused locally).
CORE_INTERNAL_URL=http://localhost:4000

# --- Observability ----------------------------------------------------------
LOG_LEVEL=info
OTEL_ENABLED=false

# --- Integrations (optional, enable per-adapter) ---------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@aires.tech
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
DOCUSEAL_API_KEY=
BLACKLINE_API_TOKEN=

# --- RAG (optional) ---------------------------------------------------------
OPENAI_API_KEY=

# --- PXP bootstrap (optional) ----------------------------------------------
# Only needed if you're running `pnpm pxp:bootstrap` to seed from PXP Mongo.
PXP_MONGO_URL=
