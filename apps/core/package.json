{
  "name": "@acme/core",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "pnpm with-env tsx watch src/server.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "tsx src/server.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/agents": "workspace:*",
    "@acme/api": "workspace:*",
    "@acme/auth": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/events": "workspace:*",
    "@acme/integrations": "workspace:*",
    "@acme/observability": "workspace:*",
    "@acme/rag": "workspace:*",
    "@acme/validators": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.3.4",
    "@t3-oss/env-core": "^0.13.8",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "bullmq": "^5.34.3",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.6.15",
    "ioredis": "^5.4.2",
    "superjson": "2.2.3",
    "tsx": "^4.19.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "^10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
