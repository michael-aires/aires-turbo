{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    }
  },
  "globalEnv": [
    "POSTGRES_URL",
    "DATABASE_URL",
    "DATABASE_POOL_MAX",
    "REDIS_URL",
    "BETTER_AUTH_SECRET",
    "CORE_PUBLIC_URL",
    "CORE_INTERNAL_URL",
    "CORS_ALLOWED_ORIGINS",
    "OPENAI_API_KEY",
    "SENDGRID_API_KEY",
    "SENDGRID_FROM_EMAIL",
    "AIRCALL_API_ID",
    "AIRCALL_API_TOKEN",
    "DOCUSEAL_API_KEY",
    "BLACKLINE_API_TOKEN",
    "LOG_LEVEL",
    "OTEL_ENABLED",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "AUTH_DISCORD_ID",
    "AUTH_DISCORD_SECRET",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_REDIRECT_PROXY_URL",
    "AUTH_SECRET",
    "PXP_MONGO_URL",
    "MONGODB_URI",
    "DEFAULT_ORG_NAME",
    "PORT",
    "SINGLE_ORG_ID",
    "MCP_SERVER_URL",
    "AGENT_HARNESS_URL",
    "AGENT_HARNESS_PORT",
    "CHAT_BOTS_URL",
    "CHAT_BOTS_INTERNAL_URL",
    "CHAT_BOTS_PORT",
    "CHAT_WEB_BASE_URL",
    "CHAT_WEB_PRODUCTION_URL",
    "CHAT_WEB_APP_NAME",
    "DEFAULT_AGENT_ID",
    "DEFAULT_AGENT_MODEL",
    "DEFAULT_AGENT_OVERRIDE",
    "BOT_INTERNAL_SECRET",
    "BOT_AGENT_ID",
    "BOT_API_KEY",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN",
    "TWILIO_WHATSAPP_FROM",
    "ANTHROPIC_API_KEY",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "CHAT_THREAD_MAX_MESSAGES",
    "AGENT_JWT_TTL_SECONDS",
    "JWKS_URL"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event"
  ]
}
